{
  "_version": "1.83.0",
  "sap.app": {
    "id": "com.wipro.project1",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.22.0",
      "toolsId": "35212e7b-963b-406c-aa34-3bd0268b6260"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.147.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.wipro.project1.i18n.i18n"
        }
      },
      
"": {
    "type": "sap.ui.model.odata.v4.ODataModel",
    "settings": {
      "serviceUrl": "/odata/v4/otp/", 
      "synchronizationMode": "None",
      "operationMode": "Server",
      "autoExpandSelect": true
    }
  }

    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
    "config": {
      "routerClass": "sap.m.routing.Router",
      "controlAggregation": "pages",
      "controlId": "app",
      "transition": "slide",
      "type": "View",
      "viewType": "XML",
      "path": "com.wipro.project1.view",
      "async": true
    },
  
    "routes": [
  
      {
        "name": "welcome",
        "pattern": "",
        "target": "welcome"
      },
  
      {
        "name": "personalDetails",
        "pattern": "personalDetails",
        "target": "personalDetails"
      },
  
      {
        "name": "verification",
        "pattern": "verification",
        "target": "verification"
      },
  
      {
        "name": "reviewSubmit",
        "pattern": "reviewSubmit",
        "target": "reviewSubmit"
      },
  
      {
        "name": "submissionSuccess",
        "pattern": "submissionSuccess",
        "target": "submissionSuccess"
      },
  
      {
        "name": "HRDashboard",
        "pattern": "HRDashboard",
        "target": "HRDashboard"
      },
  
      {
        "name": "candidateDetails",
        "pattern": "candidateDetails",
        "target": "candidateDetails"
      }
  
    ],
  
    "targets": {
  
      "welcome": {
        "id": "welcome",
        "name": "Welcome"
      },
  
      "personalDetails": {
        "id": "personalDetails",
        "name": "PersonalDetails"
      },
  
      "verification": {
        "id": "verification",
        "name": "Verification"
      },
  
      "reviewSubmit": {
        "id": "reviewSubmit",
        "name": "ReviewSubmit"
      },
  
      "submissionSuccess": {
        "id": "submissionSuccess",
        "name": "SubmissionSuccess"
      },
  
      "HRDashboard": {
        "id": "HRDashboard",
        "name": "HRDashboard"
      },
  
      "candidateDetails": {
        "id": "candidateDetails",
        "name": "CandidateDetails"
      }
  
    }
  },
    "rootView": {
      "viewName": "com.wipro.project1.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "comwiproproject1"
  }
}
