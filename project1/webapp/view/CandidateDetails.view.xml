<mvc:View
    controllerName="com.wipro.project1.controller.CandidateDetails"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Page
        showHeader="false"
        class="detailsPage"
    >
        <content>
            <!-- ================================================= -->
            <!-- HEADER -->
            <!-- ================================================= -->

            <VBox class="shellHeaderWrapper">
                <HBox
                    justifyContent="SpaceBetween"
                    alignItems="Center"
                    class="shellHeader"
                >
                    <!-- LEFT -->

                    <HBox alignItems="Center">
                        <Image
                            src="img/sap-logo.png"
                            width="54px"
                        />

                        <Title
                            text="HR Onboarding"
                            level="H4"
                            class="shellTitle"
                        />

                        <Button
                            icon="sap-icon://slim-arrow-down"
                            type="Transparent"
                        />
                    </HBox>

                    <!-- RIGHT -->

                    <HBox alignItems="Center">
                        <Button
                            icon="sap-icon://search"
                            type="Transparent"
                        />

                        <Button
                            icon="sap-icon://bell"
                            type="Transparent"
                        />

                        <Button
                            icon="sap-icon://sys-help"
                            type="Transparent"
                        />

                        <Avatar
                            initials="RS"
                            class="headerAvatar"
                        />

                        <VBox class="userInfoWrapper">
                            <Text
                                text="Ravi Sharma"
                                class="userName"
                            />

                            <Text
                                text="HR Administrator"
                                class="userRole"
                            />
                        </VBox>

                        <Button
                            icon="sap-icon://slim-arrow-down"
                            type="Transparent"
                        />
                    </HBox>
                </HBox>
            </VBox>

            <!-- ================================================= -->
            <!-- PAGE CONTENT -->
            <!-- ================================================= -->

            <VBox class="pageWrapper">
                <!-- BACK -->

                <Link
                    text="Back to Dashboard"
                    class="backLink"
                    press=".onBack"
                />

                <!-- TITLE -->

                <Title
                    text="Candidate Onboarding Details"
                    level="H1"
                    class="mainTitle"
                />

                <Text
                    text="Read-only view with controlled actions."
                    class="subTitle"
                />

                <!-- ================================================= -->
                <!-- OBJECT HEADER -->
                <!-- ================================================= -->

                <VBox class="objectHeaderCard">
                    <HBox
                        justifyContent="SpaceBetween"
                        alignItems="Start"
                    >
                        <!-- LEFT -->

                        <HBox>
                            <Avatar
                                displayShape="Circle"
                                class="candidateAvatar"
                                icon="sap-icon://person-placeholder"
                            />

                            <VBox class="candidateInfoWrapper">
                                <Title
                                    text="{candidate>/name}"
                                    level="H2"
                                    class="candidateName"
                                />

                                <HBox class="candidateMetaWrapper">
                                    <VBox class="metaItem">
                                        <Text
                                            text="Candidate ID (Avature)"
                                            class="metaLabel"
                                        />

                                        <Text
                                            text="{candidate>/candidateId}"
                                            class="metaValue"
                                        />
                                    </VBox>

                                    <VBox class="metaItem">
                                        <Text
                                            text="Position / Role"
                                            class="metaLabel"
                                        />

                                        <Text
                                            text="{candidate>/position}"
                                            class="metaValue"
                                        />
                                    </VBox>

                                    <VBox class="metaItem">
                                        <Text
                                            text="Applied On"
                                            class="metaLabel"
                                        />

                                        <Text
                                            text="{candidate>/appliedOn}"
                                            class="metaValue"
                                        />
                                    </VBox>

                                    <VBox class="metaItem">
                                        <Text
                                            text="Current Onboarding Status"
                                            class="metaLabel"
                                        />

                                        <ObjectStatus
                                            text="{candidate>/validation}"
                                            state="{= ${candidate>/validation} === 'Success' ? 'Success' : ${candidate>/validation} === 'Failed' ? 'Error' : 'Warning'}"
                                            class="statusBadge"
                                        />
                                    </VBox>
                                </HBox>
                            </VBox>
                        </HBox>

                        <!-- ACTION MENU -->

                        <MenuButton
                            icon="sap-icon://overflow"
                            type="Transparent"
                            buttonMode="Regular"
                            class="actionMenuButton"
                        >
                            <menu>
                                <Menu>
                                    <MenuItem
                                        text="Restart Onboarding"
                                        icon="sap-icon://refresh"
                                        press=".onRestart"
                                    />

                                    <MenuItem
                                        text="Cancel Onboarding"
                                        icon="sap-icon://decline"
                                        press=".onCancel"
                                    />

                                    <MenuItem
                                        text="View Audit History"
                                        icon="sap-icon://document-text"
                                        press=".onAudit"
                                    />
                                </Menu>
                            </menu>
                        </MenuButton>
                    </HBox>
                </VBox>

                <!-- ================================================= -->
                <!-- SECTION 1 -->
                <!-- ================================================= -->

                <VBox class="sectionCard">
                    <HBox
                        alignItems="Center"
                        class="sectionHeader"
                    >
                        <core:Icon
                            src="sap-icon://person-placeholder"
                            class="sectionIcon"
                        />

                        <Title
                            text="1. Personal &amp; Contact Information"
                            level="H3"
                            class="sectionTitle"
                        />
                    </HBox>

                    <HBox
                        justifyContent="SpaceBetween"
                        class="dualPanelWrapper"
                    >
                        <!-- PERSONAL -->

                        <VBox class="infoPanel">
                            <Title
                                text="Personal Information"
                                level="H4"
                                class="panelTitle"
                            />

                            <VBox class="readOnlyGrid">
                                <HBox class="dataRow">
                                    <Text
                                        text="First Name"
                                        class="label"
                                    />

                                    <Text
                                        text="{candidate>/firstName}"
                                        class="value"
                                    />
                                </HBox>

                                <HBox class="dataRow">
                                    <Text
                                        text="Last Name"
                                        class="label"
                                    />

                                    <Text
                                        text="{candidate>/lastName}"
                                        class="value"
                                    />
                                </HBox>

                                <HBox class="dataRow">
                                    <Text
                                        text="Date of Birth"
                                        class="label"
                                    />

                                    <Text
                                        text="{candidate>/dob}"
                                        class="value"
                                    />
                                </HBox>

                                <HBox class="dataRow">
                                    <Text
                                        text="Gender"
                                        class="label"
                                    />

                                    <Text
                                        text="{candidate>/gender}"
                                        class="value"
                                    />
                                </HBox>

                                <HBox class="dataRow">
                                    <Text
                                        text="Nationality"
                                        class="label"
                                    />

                                    <Text
                                        text="{candidate>/nationality}"
                                        class="value"
                                    />
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- CONTACT -->

                        <VBox class="infoPanel">
                            <Title
                                text="Contact Information"
                                level="H4"
                                class="panelTitle"
                            />

                            <VBox class="readOnlyGrid">
                                <HBox class="dataRow">
                                    <Text
                                        text="Personal Email"
                                        class="label"
                                    />

                                    <HBox>
                                        <Text
                                            text="{candidate>/email}"
                                            class="value"
                                        />

                                        <ObjectStatus
                                            text="{= (${candidate>/status} === 'CONTACT_VERIFIED' || ${candidate>/status} === 'COMPLETED') ? 'Verified' : 'Pending'}"
                                            state="{= (${candidate>/status} === 'CONTACT_VERIFIED' || ${candidate>/status} === 'COMPLETED') ? 'Success' : 'Warning'}"
                                            class="verifiedStatus"
                                        />
                                    </HBox>
                                </HBox>

                                <HBox class="dataRow">
                                    <Text
                                        text="Mobile Number"
                                        class="label"
                                    />

                                    <Text
                                        text="{candidate>/mobile}"
                                        class="value"
                                    />
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ================================================= -->
                <!-- VALIDATION SUMMARY -->
                <!-- ================================================= -->

                <VBox class="sectionCard">
                    <HBox
                        alignItems="Center"
                        class="sectionHeader"
                    >
                        <core:Icon
                            src="sap-icon://shield"
                            class="sectionIcon"
                        />

                        <Title
                            text="2. Validation Summary"
                            level="H3"
                            class="sectionTitle"
                        />
                    </HBox>

                    <HBox
                        justifyContent="SpaceBetween"
                        class="validationWrapper"
                    >
                        <!-- CARD 1 -->

                        <VBox class="validationCard">
                            <HBox justifyContent="SpaceBetween">
                                <HBox alignItems="Center">
                                    <core:Icon
                                        src="sap-icon://status-positive"
                                        class="successIcon"
                                    />

                                    <Title
                                        text="OTP Verification"
                                        level="H4"
                                    />
                                </HBox>

                                <ObjectStatus
                                    text="{= ${candidate>/validation} === 'Success' ? 'Verified' : 'Pending'}"
                                    state="{= ${candidate>/validation} === 'Success' ? 'Success' : 'Warning'}"
                                />
                            </HBox>

                            <VBox class="validationContent">
                                <HBox class="validationRow">
                                    <Text
                                        text="Status"
                                        class="label"
                                    />

                                    <Text
                                        text="{= ${candidate>/validation} === 'Success' ? 'Verified' : 'Pending'}"
                                        class="value"
                                    />
                                </HBox>

                                <HBox class="validationRow">
                                    <Text
                                        text="Verified On"
                                        class="label"
                                    />

                                    <Text
                                        text="{= ${candidate>/validation} === 'Success' ? 'Verified' : 'Pending'}"
                                        class="value"
                                    />
                                </HBox>

                                <HBox class="validationRow">
                                    <Text
                                        text="Retry Count"
                                        class="label"
                                    />

                                    <Text
                                        text="1"
                                        class="value"
                                    />
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- CARD 2 -->

                        <VBox class="validationCard">
                            <HBox justifyContent="SpaceBetween">
                                <HBox alignItems="Center">
                                    <core:Icon
                                        src="sap-icon://status-positive"
                                        class="successIcon"
                                    />

                                    <Title
                                        text="Document Validation"
                                        level="H4"
                                    />
                                </HBox>

                                <ObjectStatus
                                    text="{= ${candidate>/validation} === 'Failed' ? 'Failed' : ${candidate>/validation} === 'Success' ? 'Verified' : 'Pending'}"
                                    state="{= ${candidate>/validation} === 'Failed' ? 'Error' : ${candidate>/validation} === 'Success' ? 'Success' : 'Warning'}"
                                />
                            </HBox>

                            <VBox class="validationContent">
                                <HBox class="validationRow">
                                    <Text
                                        text="Status"
                                        class="label"
                                    />

                                    <Text
                                        text="{= ${candidate>/validation} === 'Failed' ? 'Failed' : ${candidate>/validation} === 'Success' ? 'Verified' : 'Pending'}"
                                        class="value"
                                    />
                                </HBox>

                                <HBox class="validationRow">
                                    <Text
                                        text="Validation Method"
                                        class="label"
                                    />

                                    <Text
                                        text="{= ${candidate>/reason} ? 'OCR Validation' : 'System (OCR)'}"
                                        class="value"
                                    />
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- CARD 3 -->

                        <VBox class="validationCard">
                            <HBox justifyContent="SpaceBetween">
                                <HBox alignItems="Center">
                                    <core:Icon
                                        src="sap-icon://status-positive"
                                        class="successIcon"
                                    />

                                    <Title
                                        text="Name Match Check"
                                        level="H4"
                                    />
                                </HBox>

                                <ObjectStatus
                                    text="{= ${candidate>/validation} === 'Failed' ? 'Mismatch' : 'Match'}"
                                    state="{= ${candidate>/validation} === 'Failed' ? 'Error' : 'Success'}"
                                />
                            </HBox>

                            <VBox class="validationContent">
                                <HBox class="validationRow">
                                    <Text
                                        text="Result"
                                        class="label"
                                    />

                                    <Text
                                        text="{= ${candidate>/validation} === 'Failed' ? 'Mismatch' : 'Match'}"
                                        class="value"
                                    />
                                </HBox>

                                <HBox class="validationRow">
                                    <Text
                                        text="Confidence Score"
                                        class="label"
                                    />

                                    <Text
                                        text="{= ${candidate>/validation} === 'Failed' ? '72%' : '98%'}"
                                        class="value"
                                    />
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ================================================= -->
                <!-- DOCUMENT SECTION -->
                <!-- ================================================= -->

                <VBox class="sectionCard">
                    <HBox
                        alignItems="Center"
                        class="sectionHeader"
                    >
                        <core:Icon
                            src="sap-icon://document-text"
                            class="sectionIcon"
                        />

                        <Title
                            text="3. Identity Document Details"
                            level="H3"
                            class="sectionTitle"
                        />
                    </HBox>

                    <HBox
                        justifyContent="SpaceBetween"
                        class="documentWrapper"
                    >
                        <!-- LEFT -->

                        <VBox width="60%">
                            <HBox class="dataRow">
                                <Text
                                    text="Document Type"
                                    class="label"
                                />

                                <Text
                                    text="PAN Card"
                                    class="value"
                                    visible="{= ${candidate>/validation} === 'Success' ? true : false}"
                                />
                            </HBox>

                            <HBox class="dataRow">
                                <Text
                                    text="Document Number (Masked)"
                                    class="label"
                                />

                                <Text
                                    text="{candidate>/candidateId}"
                                    class="value"
                                    visible="{= ${candidate>/validation} === 'Success' ? true : false}"
                                />
                            </HBox>

                            <HBox class="dataRow">
                                <Text
                                    text="Uploaded File Name"
                                    class="label"
                                />

                                <Text
                                    text="{= 'Document_' + ${candidate>/candidateId} + '.png'}"
                                    class="value"
                                    visible="{= ${candidate>/validation} === 'Success' ? true : false}"
                                />
                            </HBox>

                            <HBox class="dataRow">
                                <Text
                                    text="Uploaded On"
                                    class="label"
                                />

                                <Text
                                    text="{candidate>/updated}"
                                    class="value"
                                    visible="{= ${candidate>/validation} === 'Success' ? true : false}"
                                />
                            </HBox>

                            <HBox class="dataRow">
                                <Text
                                    text="Validation Status"
                                    class="label"
                                />

                                <ObjectStatus
                                    text="{= ${candidate>/validation} === 'Failed' ? 'Rejected' : ${candidate>/validation} === 'Success' ? 'Verified' : 'Pending'}"
                                    state="{= ${candidate>/validation} === 'Failed' ? 'Error' : ${candidate>/validation} === 'Success' ? 'Success' : 'Warning'}"
                                />
                            </HBox>
                        </VBox>

                        <!-- RIGHT -->

                        <VBox
                            alignItems="Center"
                            class="documentPreview"
                        >
                            <core:Icon
                                src="sap-icon://pdf-attachment"
                                class="pdfIcon"
                                visible="{= ${candidate>/validation} === 'Success' ? true : false}"
                            />

                            <Button
                                text="View Document"
                                icon="sap-icon://show"
                                type="Emphasized"
                                press=".onViewDocument"
                                visible="{= ${candidate>/validation} === 'Success' ? true : false}"
                            />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ================================================= -->
                <!-- LIFECYCLE -->
                <!-- ================================================= -->

                <VBox class="sectionCard">
                    <HBox
                        alignItems="Center"
                        class="sectionHeader"
                    >
                        <core:Icon
                            src="sap-icon://history"
                            class="sectionIcon"
                        />

                        <Title
                            text="4. Onboarding Lifecycle Overview"
                            level="H3"
                            class="sectionTitle"
                        />
                    </HBox>

                    <HBox justifyContent="SpaceBetween">
                        <VBox width="48%">
                            <HBox class="dataRow">
                                <Text
                                    text="Current Status"
                                    class="label"
                                />

                                <ObjectStatus
                                    text="{candidate>/validation}"
                                    state="{= ${candidate>/validation} === 'Success' ? 'Success' : ${candidate>/validation} === 'Failed' ? 'Error' : 'Warning'}"
                                />
                            </HBox>

                            <HBox class="dataRow">
                                <Text
                                    text="Previous Status"
                                    class="label"
                                />

                                <Text
                                    text="{= ${candidate>/validation} === 'Success' ? 'Document Verification Completed' : ${candidate>/validation} === 'Failed' ? 'Validation Failed' : 'Verification In Progress'}"
                                    class="value"
                                />
                            </HBox>
                        </VBox>

                        <VBox width="48%">
                            <HBox class="dataRow">
                                <Text
                                    text="Last Updated By"
                                    class="label"
                                />

                                <Text
                                    text="HR System"
                                    class="value"
                                />
                            </HBox>

                            <HBox class="dataRow">
                                <Text
                                    text="Next Step"
                                    class="label"
                                />

                                <Text
                                    text="{= ${candidate>/validation} === 'Success' ? 'Submitted to SuccessFactors' : ${candidate>/validation} === 'Failed' ? 'Requires HR Review' : 'Pending Verification'}"
                                    class="value"
                                />
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- INFO BAR -->

                <MessageStrip
                    text="This is a read-only view. To take action, use the options from the action menu (:) at the top right."
                    type="Information"
                    showIcon="true"
                    class="infoStrip"
                />
            </VBox>
        </content>
    </Page>
</mvc:View>
