<mvc:View
    controllerName="com.wipro.project1.controller.Welcome"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
 
    <Page
        id="welcomePage"
        showHeader="false"
        class="welcomePage">
 
        <content>
 
            <VBox class="welcomeMainContainer">
 
                <!-- ================================================= -->
                <!-- HEADER -->
                <!-- ================================================= -->
 
                <OverflowToolbar class="welcomeHeader">
 
                    <HBox
                        alignItems="Center"
                        class="headerLeftSection">
 
                        <Image
                            src="https://upload.wikimedia.org/wikipedia/commons/5/59/SAP_2011_logo.svg"
                            class="sapLogo" />
 
                        <Title
                            text="OnboardPro"
                            class="productTitle" />
 
                        <VBox class="headerDivider"></VBox>
 
                        <Button
                            text="Candidate Onboarding"
                            type="Transparent"
                            icon="sap-icon://slim-arrow-down"
                            iconFirst="false"
                            class="moduleButton" />
                    </HBox>
 
                    <ToolbarSpacer />
 
                    <HBox
                        alignItems="Center"
                        class="headerRightSection">
 
                        <Button
                            icon="sap-icon://bell"
                            type="Transparent"
                            class="headerIconBtn" />
 
                        <Button
                            icon="sap-icon://sys-help"
                            type="Transparent"
                            class="headerIconBtn" />
 
                        <Select id="roleSelect" change="onRoleChange" width="150px">
                            <core:Item key="Employee" text="Employee" />
                            <core:Item key="HR" text="HR" />
                        </Select>
                    </HBox>
 
                </OverflowToolbar>
 
                <!-- ================================================= -->
                <!-- BODY -->
                <!-- ================================================= -->
 
                <FlexBox
                    justifyContent="Center"
                    alignItems="Center"
                    class="welcomeBodyContainer">
 
                    <!-- Decorative Shapes -->
 
                    <VBox class="leftCircle"></VBox>
                    <VBox class="rightCircle"></VBox>
 
                    <VBox class="dotPatternTop"></VBox>
                    <VBox class="dotPatternBottom"></VBox>
 
                    <!-- Welcome Card -->
 
                    <VBox class="welcomeCard">
 
                        <Image
                           
                            class="welcomeIllustration" />
 
                        <Title
                            text="Welcome to OnboardPro"
                            class="welcomeTitle" />
 
                        <VBox class="welcomeUnderline"></VBox>
 
                        <Text
                            text="Your onboarding journey begins here."
                            class="welcomeDesc" />
 
                        <Text
                            text="We’re excited to have you onboard!"
                            class="welcomeDescSub" />

                        <Button
                            text="Start Onboarding"
                            type="Emphasized"
                            icon="sap-icon://navigation-right-arrow"
                            iconFirst="false"
                            press=".onStartOnboarding"
                            class="startOnboardingBtn" />
                        <!-- <Button
                            text="HR Dashboard"
                            type="Emphasized"
                            icon="sap-icon://navigation-right-arrow"
                            iconFirst="false"
                            press=".onHRPage"
                            class="startOnboardingBtn" /> -->
 
                    </VBox>
 
                </FlexBox>
 
                <!-- ================================================= -->
                <!-- FOOTER -->
                <!-- ================================================= -->
 
                <HBox
                    justifyContent="Center"
                    alignItems="Center"
                    class="welcomeFooter">
 
                    <Text
                        text="© 2025 OnboardPro. All rights reserved."
                        class="footerText" />
 
                    <Link
                        text="Privacy Policy"
                        class="footerLink" />
 
                    <Link
                        text="Terms of Use"
                        class="footerLink" />
 
                    <Link
                        text="Support"
                        class="footerLink" />
 
                </HBox>
 
            </VBox>
 
        </content>
 
    </Page>
 
</mvc:View>
