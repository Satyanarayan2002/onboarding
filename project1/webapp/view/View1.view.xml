<mvc:View
    controllerName="com.wipro.project1.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified">

    <Page
        id="page"
        title="Candidate Onboarding OTP Validation">

        <content>

            <form:SimpleForm
                id="onboardingForm"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="4"
                labelSpanS="12">

                <Label text="First Name"/>
                <Input
                    value="{onb>/firstName}"
                    required="true"/>

                <Label text="Last Name"/>
                <Input
                    value="{onb>/lastName}"
                    required="true"/>

                <Label text="Email Address"/>
                <Input
                    value="{onb>/email}"
                    type="Email"
                    required="true"/>

                <Label text="Mobile Number"/>
                <Input
                    value="{onb>/mobile}"
                    type="Tel"
                    required="true"/>

                <Label text="OTP Verification"/>

                <Button
                    text="Send OTP"
                    type="Default"
                    press=".onSendOtp"
                    enabled="true"/>

                <Input
                    placeholder="Enter OTP"
                    value="{onb>/otp}"
                    visible="{onb>/otpSent}"
                    type="Number"
                    maxLength="6"/>

                <Button
                    text="Verify OTP"
                    type="Emphasized"
                    press=".onVerifyOtp"
                    visible="{onb>/otpSent}"/>

                <Text
                    text="OTP successfully verified"
                    visible="{onb>/otpVerified}"
                    class="sapUiSmallMarginTop"
                    wrapping="true"/>

                <Label text="Upload National ID"/>
                <u:FileUploader
                    id="fileUploader"
                    width="100%"
                    buttonText="Choose File"
                    fileType="jpg,png,pdf"
                    change=".onFileUpload"/>

                <Label text=""/>

                <Button
                    text="Submit Onboarding"
                    type="Accept"
                    press=".onSubmit"
                    enabled="{onb>/otpVerified}"/>

            </form:SimpleForm>

        </content>

    </Page>

</mvc:View>


